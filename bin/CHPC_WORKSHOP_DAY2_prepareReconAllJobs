#! /bin/bash

# Prepare FreeSurfer recon-all jobs from participant DICOM folders.
# Beginners: Dont worry how this script works. You just need to be able to use it. So pay attention to the help.

###################################################################################
# NB Run this script as an interactive job. Dont run it directly on the headnode! #
###################################################################################

# Dependencies:
#   This script expects FreeSurfer to be loaded and available in your shell.
#   FreeSurfer provides the commands used here:
#     mri_probedicom  - reads values from DICOM headers
#     recon-all       - runs the FreeSurfer reconstruction
#
# Example:
#   CHPC_WORKSHOP_DAY2_prepareReconAllJobs \
#     -d /path/to/all_participant_dicoms \
#     -sd /path/to/freesurfer_subjects

set -u

# -------------------------------------------------------------------------
# Settings learners may need to change
# -------------------------------------------------------------------------
#
# This script looks for the anatomical T1 DICOM sequence that should be sent
# to recon-all.
#
# The workshop data stores that sequence in a folder with RMS in the name,
# for example:
#
#   3_tfl_mgh_me_adult_RMS
#
# If your scanner names the T1 sequence folder differently, change this first.
TARGET_SEQUENCE_DIR_PATTERN="*RMS*"

# After we find a possible sequence folder, we inspect one DICOM file from it.
# mri_probedicom prints DICOM header fields such as:
#
#   SeriesDescription
#   ProtocolName
#   SeriesNumber
#   PatientName
#   StudyDate
#   StudyTime
#
# These two settings say which DICOM field we treat as the sequence name, and
# which text we expect to find in that field.
#
# Note that the folder name and the DICOM header do not always match exactly.
# In the workshop data, the folder name ends with _RMS, but the DICOM
# SeriesDescription is just tfl_mgh_me_adult.
# If your sequence is named "t1_mprage", "MPRAGE", or something site-specific,
# change the value below.
TARGET_SEQUENCE_NAME_FIELD="SeriesDescription"
TARGET_SEQUENCE_NAME_TEXT="tfl_mgh_me_adult"

# This optional setting lets you also check a sequence ID field.
# Leave TARGET_SEQUENCE_ID_TEXT empty to ignore this check.
#
# Example:
#   TARGET_SEQUENCE_ID_FIELD="SeriesNumber"
#   TARGET_SEQUENCE_ID_TEXT="3"
TARGET_SEQUENCE_ID_FIELD="SeriesNumber"
TARGET_SEQUENCE_ID_TEXT=""

show_usage()
{
    echo "Beginners: Dont worry how this script works. You just need to be able to use it." 
    echo "So pay attention to the help below."

    echo "Usage:"
    echo "  $0 -d <dicom_parent_dir> -sd <subjects_dir>"
    echo
    echo "Example:"
    echo "  CHPC_WORKSHOP_DAY2_prepareReconAllJobs \\"
    echo "    -d /path/to/all_participant_dicoms \\"
    echo "    -sd /path/to/freesurfer_subjects"
}

find_sequence_dirs()
{
    local dicom_parent_dir="$1"

    # The workshop T1 sequence folders are usually named with RMS.
    # Each matching folder is treated as the T1 sequence for one participant.
    find "$dicom_parent_dir" -type d -name "$TARGET_SEQUENCE_DIR_PATTERN" | sort
}

read_dicom_field()
{
    local dicom_file="$1"
    local field_name="$2"

    # mri_probedicom prints many header fields.
    # This awk command finds the line whose first word is the field name and
    # prints the value beside it.
    mri_probedicom --i "$dicom_file" |
        awk -v field_name="$field_name" '$1 == field_name {print $2; exit}'
}

find_first_dicom_file()
{
    local sequence_dir="$1"

    # Each sequence folder contains many DICOM files ending in .dcm.
    # They all belong to the same sequence, so one file is enough for the
    # header information we need here.
    #
    # We sort before taking the first file so the choice is predictable.
    find "$sequence_dir" -maxdepth 1 -type f -name "*.dcm" | sort | head -n 1
}

find_t1_dicom()
{
    local sequence_dir="$1"
    local first_dicom=""
    local sequence_name=""
    local sequence_id=""

    first_dicom=$(find_first_dicom_file "$sequence_dir")

    if [ -z "$first_dicom" ]; then
        echo "Could not find a DICOM file in: $sequence_dir" >&2
        exit 1
    fi

    sequence_name=$(read_dicom_field "$first_dicom" "$TARGET_SEQUENCE_NAME_FIELD")

    if [ -z "$sequence_name" ]; then
        echo "Could not read $TARGET_SEQUENCE_NAME_FIELD from $first_dicom" >&2
        exit 1
    fi

    if [[ "$sequence_name" != *"$TARGET_SEQUENCE_NAME_TEXT"* ]]; then
        echo "This sequence does not match the expected T1 sequence name." >&2
        echo "  DICOM file: $first_dicom" >&2
        echo "  Field checked: $TARGET_SEQUENCE_NAME_FIELD" >&2
        echo "  Expected text: $TARGET_SEQUENCE_NAME_TEXT" >&2
        echo "  Actual value: $sequence_name" >&2
        exit 1
    fi

    if [ -n "$TARGET_SEQUENCE_ID_TEXT" ]; then
        sequence_id=$(read_dicom_field "$first_dicom" "$TARGET_SEQUENCE_ID_FIELD")

        if [ -z "$sequence_id" ]; then
            echo "Could not read $TARGET_SEQUENCE_ID_FIELD from $first_dicom" >&2
            exit 1
        fi

        if [[ "$sequence_id" != *"$TARGET_SEQUENCE_ID_TEXT"* ]]; then
            echo "This sequence does not match the expected T1 sequence ID." >&2
            echo "  DICOM file: $first_dicom" >&2
            echo "  Field checked: $TARGET_SEQUENCE_ID_FIELD" >&2
            echo "  Expected text: $TARGET_SEQUENCE_ID_TEXT" >&2
            echo "  Actual value: $sequence_id" >&2
            exit 1
        fi
    fi

    echo "$first_dicom"
}

read_subject_label()
{
    local t1_dicom="$1"
    local patient_name=""
    local study_date=""
    local study_time=""

    # mri_probedicom reads the DICOM header.
    patient_name=$(read_dicom_field "$t1_dicom" "PatientName")
    study_date=$(read_dicom_field "$t1_dicom" "StudyDate")
    study_time=$(read_dicom_field "$t1_dicom" "StudyTime" | cut -c 1-4)

    if [ -z "$patient_name" ] || [ -z "$study_date" ] || [ -z "$study_time" ]; then
        echo "Could not read PatientName, StudyDate, and StudyTime from $t1_dicom" >&2
        exit 1
    fi

    echo "${study_date}_${study_time}_${patient_name}"
}

write_recon_all_job()
{
    local t1_dicom="$1"
    local subjects_dir="$2"
    local subject_label="$3"
    local job_file="$subjects_dir/jobFiles/recon-all-${subject_label}.job"

    mkdir -p "$subjects_dir/jobFiles"

    {
        echo "#! /bin/bash"
        echo
        echo "#PBS -l select=1:ncpus=1"
        echo "#PBS -l walltime=48:00:00"
        echo "#PBS -N recon-all-${subject_label}"
        echo "#PBS -P WCHPC"
        echo "#PBS -q R7293126"
        echo
        echo "recon-all -i \"$t1_dicom\" -sd \"$subjects_dir\" -s \"$subject_label\" -all"
    } > "$job_file"

    echo "Prepared job file:"
    echo "  $job_file"
    echo
    echo "The recon-all command is:"
    echo "  recon-all -i \"$t1_dicom\" -sd \"$subjects_dir\" -s \"$subject_label\" -all"
}

prepare_one_participant()
{
    local sequence_dir="$1"
    local subjects_dir="$2"
    local t1_dicom=""
    local subject_label=""

    echo "T1 sequence directory:"
    echo "  $sequence_dir"

    t1_dicom=$(find_t1_dicom "$sequence_dir")
    subject_label=$(read_subject_label "$t1_dicom")

    echo "First DICOM file used for header information:"
    echo "  $t1_dicom"
    echo "Subject label from DICOM header:"
    echo "  $subject_label"
    echo

    write_recon_all_job "$t1_dicom" "$subjects_dir" "$subject_label"
    echo
}

DICOM_DIR=""
SUBJECTS_DIR=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -d|--dicom-dir)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for $1" >&2
                show_usage
                exit 1
            fi
            DICOM_DIR=$(readlink -f "$2")
            shift 2
            ;;
        -sd|--subjects-dir|-subj)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for $1" >&2
                show_usage
                exit 1
            fi
            SUBJECTS_DIR=$(readlink -f "$2")
            shift 2
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            show_usage
            exit 1
            ;;
    esac
done

if [ -z "$DICOM_DIR" ] || [ -z "$SUBJECTS_DIR" ]; then
    show_usage
    exit 1
fi

if [ ! -d "$DICOM_DIR" ]; then
    echo "DICOM directory does not exist: $DICOM_DIR" >&2
    exit 1
fi

mkdir -p "$SUBJECTS_DIR"

mapfile -t SEQUENCE_DIRS < <(find_sequence_dirs "$DICOM_DIR")

if [ "${#SEQUENCE_DIRS[@]}" -eq 0 ]; then
    echo "No matching T1 sequence folders found in: $DICOM_DIR" >&2
    echo "Expected folders matching: $TARGET_SEQUENCE_DIR_PATTERN" >&2
    exit 1
fi

echo "Found ${#SEQUENCE_DIRS[@]} matching T1 sequence folder(s)."
echo

for SEQUENCE_DIR in "${SEQUENCE_DIRS[@]}"; do
    prepare_one_participant "$SEQUENCE_DIR" "$SUBJECTS_DIR"
done
